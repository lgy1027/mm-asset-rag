# ──────────────────────────────────────────────────────────────────────────
# mm-asset-rag config template
#
# Copy to .env and fill in the values that apply. There is no offline /
# mock fallback — every provider must point at a real backend. The .env
# file is git-ignored.
# ──────────────────────────────────────────────────────────────────────────

# ─── Paths ────────────────────────────────────────────────────────────────
# MM_ASSET_RAG_HOME=/path/to/your/data

# ─── LLM / VLM (used by /answer, /chat, and image auto_meta) ───────────
# Any OpenAI-compatible chat-completions endpoint. The bundled projects
# have used local ollama (http://127.0.0.1:11434/v1) and hosted
# services like DeepSeek, Moonshot, and the MiniMax platform. The
# canonical MiniMax endpoint is https://api.minimaxi.com/v1 with the
# ``MiniMax-M3`` multimodal model — note the path is ``/v1`` (not
# ``/anthropic``) and the model is multimodal so it can replace
# PaddleOCR-VL for image auto_meta.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M3
# LLM_TIMEOUT=120

# ─── Embedding (text) ────────────────────────────────────────────────────
# Optional overrides; leave unset to reuse the OPENAI_* variables above.
# Local ollama example:
#   EMBEDDING_API_KEY=ollama
#   EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
#   EMBEDDING_MODEL=bge-m3
# Hosted service: fill the EMBEDDING_* vars and leave OPENAI_* alone.
# EMBEDDING_BACKEND=openai  # openai (default) | sentence_transformers
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
# EMBEDDING_BATCH_SIZE=5
# EMBEDDING_REQUEST_INTERVAL=0.25
# EMBEDDING_RETRY_COUNT=5
# EMBEDDING_TIMEOUT=120
# EMBEDDING_MAX_INPUT_CHARS=8192

# ─── Image embedding (CLIP) ──────────────────────────────────────────────
# Requires: pip install mm-asset-rag[clip]
# Default is the original English-only OpenAI CLIP (512d). For Chinese
# corpora swap to a multilingual model — the dim changes so the active
# Qdrant collection is created with the new dim suffix. Recommended:
#   OFA-Sys/chinese-clip-vit-base-patch16                (768d, 1.0 GB)
#   sentence-transformers/clip-ViT-B-32-multilingual-v1  (512d, 0.6 GB)
# After changing the model, run `mmrag reindex` to rebuild the image
# collection. Text→image recall on Chinese queries should jump from
# ~0% to ~70% on a Chinese-fine-tuned model.
# CLIP_MODEL=clip-ViT-B-32

# ─── Qdrant ──────────────────────────────────────────────────────────────
# Leave QDRANT_URL unset to use local file mode (default).
# QDRANT_URL=
# QDRANT_API_KEY=
# Base collection names; the active collection name is
# "{base}_{vector_size}d" (e.g. multimodal_text_2560d) and is set automatically
# at runtime based on the embedding model in use.
# QDRANT_TEXT_COLLECTION=multimodal_text
# QDRANT_IMAGE_COLLECTION=multimodal_image
# QDRANT_UPSERT_BATCH_SIZE=16
# QDRANT_BM25_MODEL=Qdrant/bm25
# QDRANT_HYBRID_PREFETCH_LIMIT=20
# Force a specific active collection (overrides the {base}_{dim}d auto
# resolution). Leave empty to use the auto suffix.
# QDRANT_ACTIVE_TEXT_COLLECTION=
# QDRANT_ACTIVE_IMAGE_COLLECTION=

# ─── Chinese BM25 ────────────────────────────────────────────────────────
# Adds a second sparse vector (``bm25_zh``) to the text collection so
# Chinese token-level recall isn't reliant on dense embeddings alone.
# Implemented in ``mm_asset_rag.bm25_zh`` (jieba + Okapi BM25). Disable
# for English-only corpora to skip the indexing cost.
# BM25_ZH_ENABLED=true
# BM25_ZH_K1=1.5
# BM25_ZH_B=0.75
# BM25_ZH_VECTOR_NAME=bm25_zh
#
# ── Upgrading from a pre-0.1 build ──────────────────────────────────────
# Toggling BM25_ZH_ENABLED (or any other setting that changes the
# Qdrant text collection's vector schema) requires a rebuild. The
# indexer now refuses to silently write partial points into an old
# collection; it raises:
#
#   RuntimeError: Qdrant collection 'multimodal_text_2560d' schema mismatch.
#     expected sparse vectors: ['bm25', 'bm25_zh']
#     actual sparse vectors:   ['bm25']
#     missing:   ['bm25_zh']
#
# After upgrading, run:
#
#   mmrag reindex
#
# (it is drop + rebuild by default.)

# ─── Retrieval tuning ─────────────────────────────────────────────────────
# Weights used by ``hybrid_search`` to merge the three routes
# (text / text-to-image / image-to-image). The defaults favour text
# evidence for plain text queries while still allowing image hits when
# their metadata and CLIP vectors are relevant.
# HYBRID_WEIGHT_TEXT=0.80
# HYBRID_WEIGHT_TEXT_TO_IMAGE=0.20
# HYBRID_WEIGHT_IMAGE_TO_IMAGE=0.0
# Per-asset chunk cap applied during indexing. Leave unset to index every
# chunk; set a value when very large PDFs crowd smaller assets out of top-k.
# MAX_CHUNKS_PER_PDF=10

# Cosine similarity floor for the image search routes. CLIP scores
# live in roughly 0.15-0.40; off-topic natural-language queries
# (e.g. "Schrödinger equation" against a photo collection) tend to
# land below 0.24 even for the closest image. Set to 0.0 to disable.
# For Chinese-CLIP the cosine band shifts lower — drop to 0.18-0.20.
# IMAGE_RELEVANCE_THRESHOLD=0.24

# Confidence floor for the merged hybrid result. After ``merge_hits``
# weights and normalises per-route scores, any result whose weighted
# score falls below ``MIN_SCORE`` is dropped. ``0.0`` keeps every
# result (default). Recommended ``0.10-0.20`` for open-ended RAG: below
# this band a 5-result top-k is mostly noise and the LLM answer is
# better off falling back to "no relevant context found" than
# hallucinating from random snippets.
# MIN_SCORE=0.30

# Per-channel RRF bias for the three text-search prefetches
# (dense / BM25-en / BM25-zh). Weights are passed positionally to
# Qdrant's ``RrfQuery(rrf=Rrf(weights=[...]))`` (server 1.17+).
# Raise ``RRF_WEIGHT_BM25_ZH`` to 1.5 to bias Chinese-only token
# recall; lower ``RRF_WEIGHT_DENSE`` to 0.7 if cross-language queries
# over-prioritise the multilingual channel. The default 1.0/1.0/1.0
# is equivalent to ``FusionQuery(fusion=Fusion.RRF)`` and uses
# Qdrant's default RRF k=60.
# RRF_WEIGHT_DENSE=1.0
# RRF_WEIGHT_BM25=1.0
# RRF_WEIGHT_BM25_ZH=1.0

# Query preprocessing flags. The BM25 channel sees the preprocessed
# form; the dense channel keeps the original query (multilingual
# embeddings are case-aware).
#   QUERY_LOWERCASE=true  — fold BM25-side text to lowercase
#   QUERY_FUZZY=true      — Levenshtein typo corrector (rescues
#                           "transformr" → "transformer", "RESNET"
#                           → "resnet", etc.)
#   QUERY_EXPANSION=false — enable a custom synonym file (path below)
# QUERY_EXPANSION_PAIRS=/path/to/pairs.json

# ─── Chunk keyword enrichment (BM25 helper) ──────────────────────────────
# Appends a "关键词: ..." footer (jieba TextRank) to every PDF chunk's
# text before indexing, so the BM25 channel has explicit tokens to match
# short queries like "联宝 ESG" against long PDF bodies where the tokens
# would otherwise be diluted. Disable for non-Chinese corpora or when
# jieba is unavailable. ``ENRICH_CHUNK_LANGUAGE=auto`` runs jieba first
# (zh) and falls back to a stopword-frequency extractor (en).
# ENRICH_CHUNK_WITH_KEYWORDS=true
# ENRICH_CHUNK_KEYWORD_TOP_K=8
# ENRICH_CHUNK_LANGUAGE=auto  # zh | en | auto

# ─── Image-route precision controls ──────────────────────────────────────
# The text→image and image→image routes build a sparse payload pre-filter
# from these fields to narrow the CLIP candidate pool before cosine
# scoring. ``IMAGE_PREFILTER_MIN_TOKEN_LEN`` drops short tokens (e.g.
# "ai") that would over-match. Set ``IMAGE_PREFILTER_FIELDS=[]`` (empty)
# to disable the pre-filter entirely.
# IMAGE_PREFILTER_FIELDS=tags,asset_id,asset_title
# IMAGE_PREFILTER_MIN_TOKEN_LEN=3

# ─── Contextual Retrieval (on by default; LLM cost) ─────────────────────
# Anthropic-style chunk context (2024, -49% retrieval failure rate):
# each chunk gets a short LLM-generated preamble situating it within its
# document, prepended to the embedding/BM25 input so dense + sparse
# channels can disambiguate generic terms ("diffusion" → DDPM vs Stable
# Diffusion). ON by default — the latency/precision trade-off favors
# precision; set CONTEXTUAL_ENABLED=false to opt out. Cost: ~1 LLM call
# per chunk at parse time (4158 PDF chunks on the bundled corpus ≈ 9.4M
# tokens). The shared OPENAI_* triple is reused; CONTEXTUAL_MODEL only
# overrides the model name (unset → OPENAI_MODEL). When OPENAI_* is
# unconfigured the whole step degrades to a no-op (no LLM call, no cache
# file) — safe to leave on. Cached under parsed/<id>/context.jsonl so
# ``mmrag reindex`` reuses it without re-calling the LLM. The CLI
# ``--contextual`` flag forces it on regardless of this setting.
# CONTEXTUAL_ENABLED=true
# CONTEXTUAL_MODEL=             # default: OPENAI_MODEL
# CONTEXTUAL_CONCURRENCY=4
# CONTEXTUAL_CHUNK_MAX_CHARS=8000
# CONTEXTUAL_TIMEOUT=60

# ─── Two-stage reranker (opt-in) ────────────────────────────────────────
# bge-m3's model card recommends "hybrid retrieval + re-ranking": pull a
# candidate pool with dense + BM25, then score each (query, doc) pair
# with a cross-encoder. Catches high-score false positives that the
# global MIN_SCORE cannot. opt-in — adds ~50-200ms latency per query and
# the model is ~600MB on first download. Runs locally via
# sentence-transformers.CrossEncoder (same dep as bge-m3 embedder); no
# ollama / API. When enabled, ``hybrid_search`` fetches RERANKER_TOP_N
# candidates, reranks, and returns RERANKER_TOP_K (or the caller's top_k
# if unset). RERANKER_TOP_N should be ≤ QDRANT_HYBRID_PREFETCH_LIMIT
# (default 20) or the candidate pool is bounded by the prefetch.
# RERANKER_ENABLED=false
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_N=20
# RERANKER_TOP_K=               # default: caller's top_k (5)

# ─── PDF embedded-image extraction (tier-1 multimodal) ──────────────────
# PyMuPDF parses text only by default; embedded figures are dropped. When
# PDF_EXTRACT_IMAGES is on, the parser pulls every image a page references
# into parsed/<id>/images/ and attaches the figures a chunk references (or
# sits next to) to the chunk's metadata["images"]. Surfaced to the LLM (a
# 关联图片 hint) and the web UI (a thumbnail via /parsed-image/<aid>/<file>).
# Images ride in the text hit's payload — they are NOT embedded into the
# vector index (that is tier 2). PDF_IMAGE_MIN_DIM filters logos/icons.
# PDF_EXTRACT_IMAGES=true
# PDF_IMAGE_MIN_DIM=80

# ─── Tier-3 multimodal answer (opt-in, needs a vision model) ────────────
# When on, /answer and /chat/stream inject the hit's associated images
# (base64 data URLs) into the chat request as image_url content parts
# alongside the text evidence, so a multimodal LLM can *see* figure pixels
# and answer questions whose answer lives in the figure (numbers / tables /
# flowcharts the body text doesn't repeat). Requires a vision-capable chat
# model — e.g. MiniMax-M3, or ollama gemma3 / llama3.2-vision. If the
# configured model rejects images, the call is retried text-only so the
# feature is safe to toggle without breaking /answer. No effect when
# PDF_EXTRACT_IMAGES is off (no images on the hits to inject).
# ANSWER_WITH_IMAGES=false
# ANSWER_IMAGE_MAX_PER_HIT=2

# ─── PDF parsing (PaddleOCR-VL, optional) ────────────────────────────────
# Used when PDF_PARSER=paddleocr_vl (or auto + token present).
# PADDLEOCR_VL_API_TOKEN=
# PADDLEOCR_VL_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
# PADDLEOCR_VL_MODEL=PaddleOCR-VL-1.6
# PADDLEOCR_VL_TIMEOUT=900
# PADDLEOCR_VL_POLL_INTERVAL=5
# PADDLEOCR_VL_POLL_RETRY=5
# PADDLEOCR_VL_USE_DOC_ORIENTATION_CLASSIFY=false
# PADDLEOCR_VL_USE_DOC_UNWARPING=false
# PADDLEOCR_VL_USE_CHART_RECOGNITION=false

# ─── Upload safety limits ────────────────────────────────────────────────
# Files over these limits are rejected before parse/index to protect the
# preview endpoint from accidental very large uploads.
# UPLOAD_MAX_FILE_BYTES=52428800
# UPLOAD_MAX_BATCH_BYTES=209715200
# UPLOAD_MAX_PDF_PAGES=500
# UPLOAD_MAX_IMAGE_PIXELS=50000000
# UPLOAD_SLUG_MAX_LEN=80
# TTL for /upload/preview staging files (seconds). Default 24h.
# PREVIEW_CACHE_TTL_SECONDS=86400

# ─── Upload auto-metadata (optional VLM JSON mode) ───────────────────────
# AUTO_META_ENABLED=true
# AUTO_META_TIMEOUT=30
# AUTO_META_MAX_TOKENS=800
# AUTO_META_MAX_CONCURRENCY=3
# AUTO_META_IMAGE_PROMPT=
# AUTO_META_PDF_PROMPT=
# AUTO_META_PDF_MAX_PAGES=100
# AUTO_META_PDF_RENDER_DPI=120
# AUTO_META_PDF_MAX_RENDER_PIXELS=8000000

# ─── Legacy parser defaults ─────────────────────────────────────────────
# Used by CLI/service defaults; the web upload flow auto-sniffs type and
# always parses + indexes confirmed previews.
# PDF parser: auto | pymupdf | paddleocr_vl
PDF_PARSER=auto
# Run local OCR HTTP for image assets (requires OCR_HTTP_URL set below).
ENABLE_OCR=false
# Run OpenAI-compatible VLM caption for image assets.
ENABLE_VLM=false
# Image embedding provider for the vector index: lite | sentence_transformers
IMAGE_PROVIDER=lite
AUTO_INDEX=true

# ─── Image OCR (local HTTP service, optional) ────────────────────────────
# OCR_HTTP_URL=http://127.0.0.1:8000/ocr
# OCR_HTTP_TIMEOUT=60

# ─── Image VLM caption (OpenAI-compatible chat, optional) ───────────────
# VLM_BASE_URL=
# VLM_API_KEY=
# VLM_MODEL=
# VLM_TEMPERATURE=0.1
# VLM_MAX_TOKENS=2000
# VLM_TIMEOUT=120