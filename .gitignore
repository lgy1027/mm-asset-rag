# Project runtime data (indices, parsed artifacts, captions, etc.)
# The library writes here at runtime; not part of source distribution.
# Leading slash = only match at the repo root, so that
# `examples/data/` (sample assets shipped with the package) is not ignored.
/data/
/indexes/
/parsed/
/captions/
/documents.jsonl
/run_report.json
/eval_report.json

# Cross-scenario test fixtures downloaded by `scripts/expand_corpus.py`.
# These PDFs are pulled at runtime from public-domain sources (Wikipedia,
# arXiv, IRS) — they are not part of the source distribution because
# they re-bloat every clone. The script is idempotent and the
# `asset_manifest.json` records the URLs to fetch.
/examples/data/chapter11_assets/pdfs/arxiv_*.pdf
/examples/data/chapter11_assets/pdfs/irs_*.pdf
/examples/data/chapter11_assets/pdfs/wiki_*.pdf
/examples/data/chapter11_assets/pdfs/*__scan.pdf

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Claude Code tooling state (project-local settings, per-machine skills)
# The repo-level CLAUDE.md at the root IS committed; only the per-user
# `.claude/` cache and skills are not.
.claude/

# Knowledge graph cache generated by the graphify hook. Safe to delete;
# rebuilt from source on the next `graphify --update` or via the
# `.git/hooks/post-commit` hook.
graphify-out/

# Manifest backup produced by ``mm_asset_rag.assets.safe_write_manifest``
# before each atomic replace. Recreatable by re-running the writer
# (e.g. ``mmrag parse`` re-derives the manifest, ``scripts/build_manifest.py``
# regenerates it from the asset directory).
asset_manifest.json.bak
indexes.json.bak
documents.jsonl.bak